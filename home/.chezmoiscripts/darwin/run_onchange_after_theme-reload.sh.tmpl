#!/bin/bash
# hash: {{ .appearance }}
# Reload running apps after appearance change

# Reload tmux config if tmux is running
if command -v tmux >/dev/null 2>&1 && tmux info >/dev/null 2>&1; then
  tmux source-file ~/.config/tmux/tmux.conf 2>/dev/null
  # Re-run catppuccin plugin explicitly so the flavor change takes effect
  if [ -f ~/.tmux/plugins/catppuccin/tmux/catppuccin.tmux ]; then
    tmux source-file ~/.tmux/plugins/catppuccin/tmux/catppuccin.tmux 2>/dev/null
  fi
  tmux refresh-client -S 2>/dev/null
fi

# Set FSH theme
if command -v fast-theme >/dev/null 2>&1; then
  fast-theme XDG:catppuccin-{{ if eq .appearance "light" }}latte{{ else }}mocha{{ end }} >/dev/null 2>&1
fi
