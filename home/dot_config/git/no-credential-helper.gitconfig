# Shared by every path listed in $noAuthGitDirs in ~/.gitconfig's template.
# Plugin managers (TPM, lazy.nvim, etc.) clone/pull over HTTPS from github.com.
# Without this override, every pull re-triggers the 1Password-backed credential
# helper for a public, read-only repo that needs no auth at all -- clearing the
# helper here lets git fall back to anonymous HTTPS for just these paths.
[credential "https://github.com"]
  helper =
[credential "https://gist.github.com"]
  helper =
