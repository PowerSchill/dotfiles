{
  "version": 3,
  "colorLevel": 3,
  "flexMode": "full-minus-40",
  "compactThreshold": 60,
  "defaultPadding": " ",
  "inheritSeparatorColors": false,
  "globalBold": false,
  "gitCacheTtlSeconds": 5,
  "minimalistMode": false,
  "powerline": {
    "enabled": true,
    "theme": "custom",
    "separators": [
      ""
    ],
    "separatorInvertBackground": [
      false
    ],
    "startCaps": [
      ""
    ],
    "endCaps": [
      ""
    ],
    "autoAlign": false,
    "continueThemeAcrossLines": false
  },
  "lines": [
    [
      {
        "id": "model",
        "type": "model",
        "backgroundColor": "hex:313244",
        "color": "hex:CBA6F7",
        "bold": true,
        "rawValue": true
      },
      {
        "id": "cwd",
        "type": "current-working-dir",
        "backgroundColor": "hex:1E1E2E",
        "color": "hex:89B4FA",
        "rawValue": true,
        "metadata": {
          "abbreviateHome": "true",
          "segments": "2"
        }
      },
      {
        "id": "git-branch",
        "type": "git-branch",
        "backgroundColor": "hex:313244",
        "color": "hex:A6E3A1",
        "rawValue": true,
        "maxWidth": 24,
        "metadata": {
          "hideNoGit": "true"
        }
      },
      {
        "id": "git-changes",
        "type": "git-changes",
        "backgroundColor": "hex:1E1E2E",
        "color": "hex:FAB387",
        "metadata": {
          "hideNoGit": "true"
        }
      },
      {
        "id": "worktree-name",
        "type": "worktree-name",
        "backgroundColor": "hex:313244",
        "color": "hex:94E2D5"
      }
    ],
    [
      {
        "id": "context-bar",
        "type": "context-bar",
        "backgroundColor": "hex:313244",
        "color": "hex:89DCEB",
        "rawValue": true,
        "metadata": {
          "display": "slider"
        }
      },
      {
        "id": "session-cost",
        "type": "session-cost",
        "backgroundColor": "hex:1E1E2E",
        "color": "hex:F9E2AF",
        "rawValue": true
      },
      {
        "id": "session-clock",
        "type": "session-clock",
        "backgroundColor": "hex:313244",
        "color": "hex:B4BEFE",
        "rawValue": true
      },
      {
        "id": "block-timer",
        "type": "block-timer",
        "backgroundColor": "hex:1E1E2E",
        "color": "hex:F5C2E7",
        "metadata": {
          "compact": "true"
        }
      },
      {
        "id": "session-usage",
        "type": "session-usage",
        "backgroundColor": "hex:313244",
        "color": "hex:EBA0AC"
      },
      {
        "id": "weekly-usage",
        "type": "weekly-usage",
        "backgroundColor": "hex:1E1E2E",
        "color": "hex:F38BA8"
      }
    ]
  ]
}
